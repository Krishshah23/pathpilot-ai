# ── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Database (MongoDB Atlas) ───────────────────────────
# Get this from Atlas → Connect → Drivers. Include the DB name, e.g. /pathpilot
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pathpilot?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_to_a_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_REFRESH_EXPIRES=7d

# Secret used to sign email-verification / password-reset tokens
TOKEN_SECRET=change_me_email_token_secret

# ── Django AI Service ──────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
# Must match INTERNAL_API_KEY in ai-service/.env
INTERNAL_API_KEY=dev-internal-key

# ── Email (Nodemailer) ─────────────────────────────────
# For dev you can leave these blank — emails are logged to the console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="PathPilot AI <no-reply@pathpilot.ai>"

# ── Adzuna Job Market API (Phase 1) ───────────────────
# Free registration at https://developer.adzuna.com
# Omit these to disable live market-data features.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
